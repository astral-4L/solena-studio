# Global Caddy config for Railway / any host that runs Caddy.
# Serves the statically pre-rendered TanStack Start output.
{
	admin off
	persist_config off
	auto_https off

	log { format json }

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log { format json }

	respond /health 200

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Long cache for hashed build assets (Vite emits content-hashed filenames).
	@assets path /_build/* /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Long cache for static media (images, video, fonts).
	@media path *.png *.jpg *.jpeg *.webp *.avif *.gif *.svg *.ico *.mp4 *.webm *.woff *.woff2 *.ttf *.otf
	header @media Cache-Control "public, max-age=31536000, immutable"

	# HTML must revalidate so deploys roll out immediately.
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"

	root * /app/dist/server

	file_server {
		hide .git
		hide .env*
	}

	encode { gzip zstd }

	try_files {path} {path}.html {path}/index.html /index.html
}
