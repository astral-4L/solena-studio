# Global Caddy config for Railway / any host that runs Caddy.
# Serves the statically pre-rendered TanStack Start output.
{
	admin off
	persist_config off
	auto_https off

	log { format json }

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:80} {
	log { format json }

	respond /health 200

	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	# Pre-rendered static output from `vite build` (nitro preset: static).
	root * /app/dist/server

	file_server {
		hide .git
		hide .env*
	}

	encode { gzip zstd }

	# SPA-style fallback: try the file, then folder index, then root index.
	try_files {path} {path}.html {path}/index.html /index.html
}
